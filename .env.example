APP_ENV=local
DEFAULT_CLINIC_ID=smilecare_dental
DEFAULT_TIMEZONE=Asia/Kolkata
ADMIN_API_KEY=change-me

# Google Calendar API
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Firebase Admin SDK
FIREBASE_CREDENTIALS_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
FIREBASE_PROJECT_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TEST_TO_NUMBER=
TWILIO_USE_TEST_NUMBER=false

# Note: On Render, set these values in the service dashboard rather than relying on a local .env file.

